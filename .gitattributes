# Default: auto-detect text files, normalize to LF in the repo, LF in working tree
* text=auto eol=lf

# Windows-native scripts must check out with CRLF so they run cleanly in
# PowerShell ISE, cmd.exe, and older Windows hosts. Repo storage stays LF.
*.ps1    text eol=crlf
*.psm1   text eol=crlf
*.psd1   text eol=crlf
*.ps1xml text eol=crlf
*.bat    text eol=crlf
*.cmd    text eol=crlf

# Shell scripts and config — explicit LF
*.sh         text eol=lf
*.gitignore  text eol=lf

# Binaries — never convert
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.zip  binary
*.exe  binary
*.dll  binary
*.pfx  binary
*.cer  binary
*.crt  binary
